@using Kuestencode.Rapport.Services
@using System.ComponentModel.DataAnnotations
@using Kuestencode.Shared.Contracts.Host
@page "/time-entries/create"
@inject TimeEntryService TimeEntryService
@inject SettingsService SettingsService
@inject ICustomerService CustomerService
@inject IProjectService ProjectService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IUserContextService UserContextService
@inject TeamMemberCacheService TeamMemberCacheService

<PageTitle>Manueller Eintrag - Küstencode Rapport</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Manueller Eintrag</MudText>

<MudPaper Elevation="2" Class="pa-6">
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudDatePicker Label="Datum" @bind-Date="_date" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField Label="Startzeit" Variant="Variant.Outlined"
                          InputType="InputType.Time"
                          Value="@(_startTime.HasValue ? _startTime.Value.ToString(@"hh\:mm") : "")"
                          ValueChanged="@((string v) => { _startTime = TimeSpan.TryParse(v, out var t) ? t : null; UpdateDuration(); })" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField Label="Endzeit" Variant="Variant.Outlined"
                          InputType="InputType.Time"
                          Value="@(_endTime.HasValue ? _endTime.Value.ToString(@"hh\:mm") : "")"
                          ValueChanged="@((string v) => { _endTime = TimeSpan.TryParse(v, out var t) ? t : null; UpdateDuration(); })" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudNumericField T="int" Label="Pause (min)" Variant="Variant.Outlined" Min="0"
                             Value="_breakMinutes"
                             ValueChanged="@((int v) => { _breakMinutes = v; UpdateDuration(); })" />
        </MudItem>
        <MudItem xs="12" md="3" Class="d-flex align-center">
            <MudText Typo="Typo.subtitle2">Netto-Dauer: @_durationDisplay</MudText>
        </MudItem>
        @if (_isAdminOrBuero)
        {
            <MudItem xs="12" md="6" Class="d-flex align-end gap-2">
                <MudSelect T="Guid?" Label="Mitarbeiter" @bind-Value="_selectedTeamMemberId" Variant="Variant.Outlined" Style="flex: 1">
                    @foreach (var member in _teamMembers)
                    {
                        <MudSelectItem T="Guid?" Value="@member.Id">@member.DisplayName</MudSelectItem>
                    }
                </MudSelect>
                <MudTooltip Text="Mitarbeiterliste aktualisieren">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshTeamMembersAsync" />
                </MudTooltip>
            </MudItem>
        }
        <MudItem xs="12" md="6">
            <ProjectSelector Projects="_projects"
                             IsAvailable="_projectsAvailable"
                             SelectedProjectId="_selectedProjectId"
                             SelectedProjectIdChanged="OnProjectSelected"
                             UnavailableHref="/settings/modules" />
        </MudItem>
        <MudItem xs="12" md="6">
            <CustomerPicker Customers="_customers"
                            SelectedCustomer="_selectedCustomer"
                            SelectedCustomerChanged="OnCustomerChanged"
                            OnCustomerCreated="OnNewCustomerCreated"
                            Disabled="@(_selectedProjectId.HasValue)"
                            Required="@(!_selectedProjectId.HasValue)"
                            RequiredError="Kunde ist erforderlich" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField T="string" Label="Beschreibung" Variant="Variant.Outlined"
                          @bind-Value="_description" />
        </MudItem>
        <MudItem xs="12" Class="d-flex gap-2 flex-wrap">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SaveAsync(false))">
                Speichern
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="@(() => SaveAsync(true))">
                Speichern &amp; Weiteren hinzufügen
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="Cancel">Abbrechen</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    private DateTime? _date = DateTime.Today;
    private TimeSpan? _startTime;
    private TimeSpan? _endTime;
    private int _breakMinutes;
    private string? _description;
    private List<Customer> _customers = new();
    private List<IProject> _projects = new();
    private bool _projectsAvailable;
    private RapportSettings? _settings;
    private Customer? _selectedCustomer;
    private IProject? _selectedProject;
    private int? _selectedProjectId;
    private string _durationDisplay = "00:00:00";
    private bool _isAdminOrBuero;
    private List<TeamMemberDto> _teamMembers = new();
    private Guid? _selectedTeamMemberId;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetSettingsAsync();
        _customers = await CustomerService.GetAllAsync();

        _isAdminOrBuero = await UserContextService.IsAdminOrBueroAsync();
        var currentUserId = await UserContextService.GetCurrentUserIdAsync();
        var currentUserName = await UserContextService.GetCurrentUserNameAsync();

        if (_isAdminOrBuero)
        {
            _teamMembers = await TeamMemberCacheService.GetActiveTeamMembersAsync();

            // Ensure current user is selectable/displayed even if cache/API is temporarily incomplete.
            if (currentUserId.HasValue && _teamMembers.All(m => m.Id != currentUserId.Value))
            {
                _teamMembers.Insert(0, new TeamMemberDto
                {
                    Id = currentUserId.Value,
                    DisplayName = string.IsNullOrWhiteSpace(currentUserName) ? "Aktueller Benutzer" : currentUserName,
                    Email = string.Empty,
                    Role = string.Empty,
                    IsActive = true
                });
            }
        }

        _selectedTeamMemberId = currentUserId;
    }

    private async Task RefreshTeamMembersAsync()
    {
        TeamMemberCacheService.InvalidateCache();
        var currentUserId = await UserContextService.GetCurrentUserIdAsync();
        var currentUserName = await UserContextService.GetCurrentUserNameAsync();
        _teamMembers = await TeamMemberCacheService.GetActiveTeamMembersAsync();
        if (currentUserId.HasValue && _teamMembers.All(m => m.Id != currentUserId.Value))
        {
            _teamMembers.Insert(0, new TeamMemberDto
            {
                Id = currentUserId.Value,
                DisplayName = string.IsNullOrWhiteSpace(currentUserName) ? "Aktueller Benutzer" : currentUserName,
                Email = string.Empty,
                Role = string.Empty,
                IsActive = true
            });
        }
        StateHasChanged();
    }

    private Task OnProjectSelected(int? projectId)
    {
        _selectedProjectId = projectId;
        _selectedProject = projectId.HasValue
            ? _projects.FirstOrDefault(p => p.Id == projectId.Value)
            : null;

        if (_selectedProject == null)
        {
            _selectedCustomer = null;
            return Task.CompletedTask;
        }

        var match = _customers.FirstOrDefault(c => c.Id == _selectedProject.CustomerId);
        _selectedCustomer = match ?? new Customer
        {
            Id = _selectedProject.CustomerId,
            Name = _selectedProject.CustomerName,
            CustomerNumber = "-",
            Address = string.Empty,
            PostalCode = string.Empty,
            City = string.Empty,
            Country = string.Empty
        };

        return Task.CompletedTask;
    }

    private Task OnCustomerChanged(Customer? customer)
    {
        _selectedCustomer = customer;
        return Task.CompletedTask;
    }

    private async Task OnNewCustomerCreated(Customer customer)
    {
        _customers = await CustomerService.GetAllAsync();
        _selectedCustomer = _customers.FirstOrDefault(c => c.Id == customer.Id) ?? customer;
        StateHasChanged();
    }

    private async Task SaveAsync(bool continueAdding)
    {
        if (_date == null || _startTime == null || _endTime == null)
        {
            Snackbar.Add("Bitte Datum sowie Start- und Endzeit auswählen.", Severity.Warning);
            return;
        }

        if (!_selectedProjectId.HasValue && _selectedCustomer == null)
        {
            Snackbar.Add("Bitte wähle einen Kunden oder ein Projekt.", Severity.Warning);
            return;
        }

        var startLocal = _date.Value.Date + _startTime.Value;
        var endLocal = _date.Value.Date + _endTime.Value;
        var startUtc = RapportTimeZone.BerlinToUtc(startLocal);
        var endUtc = RapportTimeZone.BerlinToUtc(endLocal);

        try
        {
            var currentUserId = await UserContextService.GetCurrentUserIdAsync();
            var currentUserName = await UserContextService.GetCurrentUserNameAsync();

            Guid? teamMemberId = currentUserId;
            string? teamMemberName = currentUserName;

            int? mitarbeiterRolleId;
            string? mitarbeiterRolleName;
            if (_isAdminOrBuero && _selectedTeamMemberId.HasValue)
            {
                teamMemberId = _selectedTeamMemberId;
                var member = await TeamMemberCacheService.GetByIdAsync(_selectedTeamMemberId.Value);
                if (teamMemberId != currentUserId)
                    teamMemberName = member?.DisplayName ?? currentUserName;
                mitarbeiterRolleId = member?.MitarbeiterRolleId;
                mitarbeiterRolleName = member?.MitarbeiterRolleName;
            }
            else
            {
                var rolle = await UserContextService.GetCurrentUserMitarbeiterRolleAsync();
                mitarbeiterRolleId = rolle.RolleId;
                mitarbeiterRolleName = rolle.RolleName;
            }

            await TimeEntryService.CreateManualEntryAsync(
                startUtc,
                endUtc,
                _selectedProjectId,
                _selectedProjectId.HasValue ? null : _selectedCustomer?.Id,
                _description,
                teamMemberId,
                teamMemberName,
                mitarbeiterRolleId,
                mitarbeiterRolleName,
                _breakMinutes);

            Snackbar.Add("Eintrag wurde gespeichert.", Severity.Success);

            if (continueAdding)
            {
                // Nächsten Eintrag vorausfüllen: Startzeit = bisherige Endzeit, Rest leer
                _startTime = _endTime;
                _endTime = null;
                _breakMinutes = 0;
                _description = null;
                UpdateDuration();
                StateHasChanged();
            }
            else
            {
                NavigationManager.NavigateTo("/rapport/time-entries");
            }
        }
        catch (ValidationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/rapport/time-entries");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        UpdateDuration();

        _projectsAvailable = await ProjectService.IsAvailableAsync();
        if (_projectsAvailable)
        {
            _projects = (await ProjectService.GetAllProjectsAsync()).ToList();
            if (_settings?.DefaultProjectId.HasValue == true)
                await OnProjectSelected(_settings.DefaultProjectId);
        }
        StateHasChanged();
    }

    private void UpdateDuration()
    {
        if (_startTime == null || _endTime == null)
        {
            _durationDisplay = "00:00:00";
            return;
        }

        var gross = _endTime.Value - _startTime.Value;
        var net = gross - TimeSpan.FromMinutes(_breakMinutes);
        _durationDisplay = net <= TimeSpan.Zero ? "00:00:00" : FormatDuration(net);
    }

    private static string FormatDuration(TimeSpan duration)
    {
        var totalHours = (int)duration.TotalHours;
        return $"{totalHours:00}:{duration.Minutes:00}:{duration.Seconds:00}";
    }
}


