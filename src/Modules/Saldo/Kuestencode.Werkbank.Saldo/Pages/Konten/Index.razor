@page "/konten"
@using Kuestencode.Shared.UI.Pages
@inject IKontoService KontoService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Saldo - Konten & Mappings</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Konten & Kategorie-Mappings</MudText>

    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">
        <MudTabPanel Text="Kategorie-Mappings">
            @if (_loadingMappings)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4" />
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-3 mt-3">
                    Ordnen Sie jeder Recepta-Kategorie das passende Buchungskonto zu.
                </MudText>
                <MudTable Items="_mappings" Dense="true" Hover="true" Elevation="0" SortLabel="Sortieren nach" T="KategorieKontoMappingDto">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<KategorieKontoMappingDto, object>(x => x.ReceiptaKategorie)" InitialDirection="@_mappingSort.InitialDirectionFor("kategorie")" SortDirectionChanged="@(d => _mappingSort.Update("kategorie", d))">Kategorie</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KategorieKontoMappingDto, object>(x => x.KontoNummer)" InitialDirection="@_mappingSort.InitialDirectionFor("konto")" SortDirectionChanged="@(d => _mappingSort.Update("konto", d))">Konto</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KategorieKontoMappingDto, object>(x => x.KontoBezeichnung)" InitialDirection="@_mappingSort.InitialDirectionFor("bezeichnung")" SortDirectionChanged="@(d => _mappingSort.Update("bezeichnung", d))">Kontobezeichnung</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KategorieKontoMappingDto, object>(x => x.IsCustom)" InitialDirection="@_mappingSort.InitialDirectionFor("typ")" SortDirectionChanged="@(d => _mappingSort.Update("typ", d))">Typ</MudTableSortLabel></MudTh>
                        <MudTh>Aktionen</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.ReceiptaKategorie</MudTd>
                        <MudTd>
                            @if (_editingId == context.Id)
                            {
                                <MudSelect @bind-Value="_editKontoNummer" Dense="true" Variant="Variant.Outlined">
                                    @foreach (var konto in _konten)
                                    {
                                        <MudSelectItem Value="@konto.KontoNummer">@konto.KontoNummer - @konto.KontoBezeichnung</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                @context.KontoNummer
                            }
                        </MudTd>
                        <MudTd>@context.KontoBezeichnung</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsCustom ? Color.Warning : Color.Default)">
                                @(context.IsCustom ? "Benutzerdefiniert" : "Standard")
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            @if (_editingId == context.Id)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success"
                                             Size="Size.Small" OnClick="@(() => SaveMappingAsync(context.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Default"
                                             Size="Size.Small" OnClick="CancelEdit" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                             Size="Size.Small" OnClick="@(() => StartEdit(context))" />
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Kontenstamm">
            @if (_loadingKonten)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4" />
            }
            else
            {
                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateKontoDialog">
                        Neues Konto
                    </MudButton>
                </MudStack>
                <MudTable Items="_konten" Dense="true" Hover="true" Elevation="0" Class="mt-3" SortLabel="Sortieren nach" T="KontoDto">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<KontoDto, object>(x => x.Kontenrahmen)" InitialDirection="@_kontoSort.InitialDirectionFor("kontenrahmen")" SortDirectionChanged="@(d => _kontoSort.Update("kontenrahmen", d))">Kontenrahmen</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KontoDto, object>(x => x.KontoNummer)" InitialDirection="@_kontoSort.InitialDirectionFor("nummer")" SortDirectionChanged="@(d => _kontoSort.Update("nummer", d))">Nummer</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KontoDto, object>(x => x.KontoBezeichnung)" InitialDirection="@_kontoSort.InitialDirectionFor("bezeichnung")" SortDirectionChanged="@(d => _kontoSort.Update("bezeichnung", d))">Bezeichnung</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KontoDto, object>(x => x.KontoTyp)" InitialDirection="@_kontoSort.InitialDirectionFor("typ")" SortDirectionChanged="@(d => _kontoSort.Update("typ", d))">Typ</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KontoDto, object>(x => x.UstSatz ?? -1)" InitialDirection="@_kontoSort.InitialDirectionFor("ust")" SortDirectionChanged="@(d => _kontoSort.Update("ust", d))">USt-Satz</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KontoDto, object>(x => x.IsActive)" InitialDirection="@_kontoSort.InitialDirectionFor("aktiv")" SortDirectionChanged="@(d => _kontoSort.Update("aktiv", d))">Aktiv</MudTableSortLabel></MudTh>
                        <MudTh>Aktionen</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Kontenrahmen</MudTd>
                        <MudTd>@context.KontoNummer</MudTd>
                        <MudTd>@context.KontoBezeichnung</MudTd>
                        <MudTd>@context.KontoTyp</MudTd>
                        <MudTd>@(context.UstSatz.HasValue ? $"{context.UstSatz}%" : "-")</MudTd>
                        <MudTd>
                            <MudIcon Icon="@(context.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                    Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small" />
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                          Size="Size.Small" OnClick="@(() => OpenEditKontoDialog(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private List<KontoDto> _konten = new();
    private List<KategorieKontoMappingDto> _mappings = new();
    private bool _loadingKonten = true;
    private bool _loadingMappings = true;
    private Guid? _editingId;
    private string _editKontoNummer = string.Empty;
    private TableSortSync _mappingSort = null!;
    private TableSortSync _kontoSort = null!;

    protected override async Task OnInitializedAsync()
    {
        _mappingSort = new TableSortSync(NavigationManager, "mapping");
        _kontoSort = new TableSortSync(NavigationManager, "konto");
        await LoadKontenAsync();
        await LoadMappingsAsync();
    }

    private async Task LoadKontenAsync()
    {
        _konten = await KontoService.GetKontenAsync();
        _loadingKonten = false;
    }

    private async Task OpenCreateKontoDialog()
    {
        var parameters = new DialogParameters();
        var dialog = await DialogService.ShowAsync<KontoDialog>("Neues Konto", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        try
        {
            await KontoService.CreateKontoAsync((CreateKontoDto)result.Data!);
            Snackbar.Add("Konto angelegt.", Severity.Success);
            await LoadKontenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenEditKontoDialog(KontoDto konto)
    {
        var parameters = new DialogParameters
        {
            { nameof(KontoDialog.ExistingKonto), konto }
        };
        var dialog = await DialogService.ShowAsync<KontoDialog>("Konto bearbeiten", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        try
        {
            await KontoService.UpdateKontoAsync(konto.Id, (UpdateKontoDto)result.Data!);
            Snackbar.Add("Konto aktualisiert.", Severity.Success);
            await LoadKontenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadMappingsAsync()
    {
        _mappings = await KontoService.GetMappingsAsync();
        _loadingMappings = false;
    }

    private void StartEdit(KategorieKontoMappingDto mapping)
    {
        _editingId = mapping.Id;
        _editKontoNummer = mapping.KontoNummer;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editKontoNummer = string.Empty;
    }

    private async Task SaveMappingAsync(Guid id)
    {
        try
        {
            var result = await KontoService.UpdateMappingAsync(id, new UpdateKategorieKontoMappingDto
            {
                KontoNummer = _editKontoNummer
            });
            if (result != null)
            {
                var idx = _mappings.FindIndex(m => m.Id == id);
                if (idx >= 0) _mappings[idx] = result;
                Snackbar.Add("Mapping gespeichert.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally
        {
            CancelEdit();
        }
    }
}
