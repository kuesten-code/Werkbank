@page "/"
@inject ISaldoAggregationService SaldoService
@inject IDatevExportService ExportService
@inject ICompanyService CompanyService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Saldo - Übersicht</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h4">Saldo Übersicht</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_von.ToString("dd.MM.yyyy") – @_bis.ToString("dd.MM.yyyy")
        </MudText>
    </MudStack>

    @* Zeitraum-Auswahl *@
    <MudPaper Class="pa-3 mb-4" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                <MudButton Color="@(_zeitraum == Zeitraum.Monat ? Color.Primary : Color.Default)"
                           Variant="@(_zeitraum == Zeitraum.Monat ? Variant.Filled : Variant.Outlined)"
                           OnClick="@(() => SetZeitraum(Zeitraum.Monat))">Monat</MudButton>
                <MudButton Color="@(_zeitraum == Zeitraum.Quartal ? Color.Primary : Color.Default)"
                           Variant="@(_zeitraum == Zeitraum.Quartal ? Variant.Filled : Variant.Outlined)"
                           OnClick="@(() => SetZeitraum(Zeitraum.Quartal))">Quartal</MudButton>
                <MudButton Color="@(_zeitraum == Zeitraum.Jahr ? Color.Primary : Color.Default)"
                           Variant="@(_zeitraum == Zeitraum.Jahr ? Variant.Filled : Variant.Outlined)"
                           OnClick="@(() => SetZeitraum(Zeitraum.Jahr))">Jahr</MudButton>
            </MudButtonGroup>

            <MudSelect @bind-Value="_ausgewaehltesJahr" T="int" Dense="true" Variant="Variant.Outlined"
                       Style="max-width: 100px;" @bind-Value:after="OnJahrChanged">
                @foreach (var jahr in _verfuegbareJahre)
                {
                    <MudSelectItem T="int" Value="@jahr">@jahr</MudSelectItem>
                }
            </MudSelect>

            @if (_zeitraum == Zeitraum.Monat)
            {
                <MudSelect @bind-Value="_ausgewaehlterMonat" T="int" Dense="true" Variant="Variant.Outlined"
                           Style="max-width: 140px;" @bind-Value:after="ApplyZeitraumAndLoad">
                    @foreach (var m in _monate)
                    {
                        <MudSelectItem T="int" Value="@m.Nummer">@m.Name</MudSelectItem>
                    }
                </MudSelect>
            }

            @if (_zeitraum == Zeitraum.Quartal)
            {
                <MudSelect @bind-Value="_ausgewaehlteQuartal" T="int" Dense="true" Variant="Variant.Outlined"
                           Style="max-width: 80px;" @bind-Value:after="ApplyZeitraumAndLoad">
                    <MudSelectItem T="int" Value="1">Q1</MudSelectItem>
                    <MudSelectItem T="int" Value="2">Q2</MudSelectItem>
                    <MudSelectItem T="int" Value="3">Q3</MudSelectItem>
                    <MudSelectItem T="int" Value="4">Q4</MudSelectItem>
                </MudSelect>
            }
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* Übersichts-Karten *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="border-left: 4px solid #4caf50;">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">EINNAHMEN</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Medium" />
                        <MudText Typo="Typo.h5" Color="Color.Success">
                            @(_uebersicht?.Einnahmen.ToString("C") ?? "–")
                        </MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_anzahlEinnahmen Buchungen
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="border-left: 4px solid #f44336;">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">AUSGABEN</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" Size="Size.Medium" />
                        <MudText Typo="Typo.h5" Color="Color.Error">
                            @(_uebersicht?.Ausgaben.ToString("C") ?? "–")
                        </MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_anzahlAusgaben Buchungen
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="@GetSaldoBorderStyle(_uebersicht?.Saldo ?? 0)">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">SALDO</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="@((_uebersicht?.Saldo ?? 0) >= 0 ? Color.Success : Color.Error)" Size="Size.Medium" />
                        <MudText Typo="Typo.h5" Color="@((_uebersicht?.Saldo ?? 0) >= 0 ? Color.Success : Color.Error)">
                            @(_uebersicht != null ? (_uebersicht.Saldo).ToString("C") : "–")
                        </MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="@((_uebersicht?.Saldo ?? 0) >= 0 ? Color.Success : Color.Error)">
                        @if (_uebersicht != null)
                        {
                            @((_uebersicht.Saldo) >= 0 ? "Gewinn" : "Verlust")
                        }
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* USt-Kurzinfo *@
    @if (_uebersicht != null && !_istKleinunternehmer)
    {
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Umsatzsteuer</MudText>
                    <MudText Typo="Typo.body1">@_uebersicht.Umsatzsteuer.ToString("C")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Vorsteuer</MudText>
                    <MudText Typo="Typo.body1">@_uebersicht.Vorsteuer.ToString("C")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">USt-Zahllast</MudText>
                    <MudText Typo="Typo.body1"
                             Color="@(_uebersicht.UstZahllast >= 0 ? Color.Default : Color.Success)">
                        @_uebersicht.UstZahllast.ToString("C")
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Zeitraum</MudText>
                    <MudText Typo="Typo.body2">
                        @_von.ToString("dd.MM.yy") – @_bis.ToString("dd.MM.yy")
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    @if (_istKleinunternehmer)
    {
        <MudAlert Severity="Severity.Info" Class="mb-6" Dense="true">
            Kleinunternehmer nach §19 UStG – keine Umsatzsteuer.
        </MudAlert>
    }

    @* Quick-Actions *@
    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Aktionen</MudText>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="ExportDatevAsync" Disabled="@_exportingDatev">
                @if (_exportingDatev)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                DATEV Export
            </MudButton>

            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FolderZip"
                       OnClick="ExportBelegeAsync" Disabled="@_exportingBelege">
                @if (_exportingBelege)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Belege (ZIP)
            </MudButton>

            <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />

            <MudButton Variant="Variant.Text" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ListAlt"
                       OnClick="@(() => NavigationManager.NavigateTo("/saldo/buchungen"))">
                Buchungen
            </MudButton>

            <MudButton Variant="Variant.Text" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Analytics"
                       OnClick="@(() => NavigationManager.NavigateTo("/saldo/euer"))">
                EÜR Detail
            </MudButton>

            @if (!_istKleinunternehmer)
            {
                <MudButton Variant="Variant.Text" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Receipt"
                           OnClick="@(() => NavigationManager.NavigateTo("/saldo/ust"))">
                    USt-Übersicht
                </MudButton>
            }

            <MudButton Variant="Variant.Text" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.History"
                       OnClick="@(() => NavigationManager.NavigateTo("/saldo/export/historie"))">
                Export-Historie
            </MudButton>
        </MudStack>
    </MudPaper>

</MudContainer>

@code {
    private enum Zeitraum { Monat, Quartal, Jahr }

    private record MonatInfo(int Nummer, string Name);

    private bool _loading = true;
    private bool _exportingDatev = false;
    private bool _exportingBelege = false;

    private SaldoUebersichtDto? _uebersicht;
    private int _anzahlEinnahmen;
    private int _anzahlAusgaben;
    private bool _istKleinunternehmer;

    private Zeitraum _zeitraum = Zeitraum.Jahr;
    private int _ausgewaehltesJahr = DateTime.Today.Year;
    private int _ausgewaehlterMonat = DateTime.Today.Month;
    private int _ausgewaehlteQuartal = (DateTime.Today.Month - 1) / 3 + 1;

    private DateOnly _von;
    private DateOnly _bis;

    private List<int> _verfuegbareJahre = Enumerable.Range(DateTime.Today.Year - 4, 6).Reverse().ToList();

    private List<MonatInfo> _monate = Enumerable.Range(1, 12)
        .Select(m => new MonatInfo(m, new DateTime(2000, m, 1).ToString("MMMM")))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        try { var company = await CompanyService.GetCompanyAsync(); _istKleinunternehmer = company?.IsKleinunternehmer ?? false; } catch { }
        ApplyZeitraum();
        await LoadDataAsync();
    }

    private void SetZeitraum(Zeitraum z)
    {
        _zeitraum = z;
        ApplyZeitraum();
        _ = LoadDataAsync();
    }

    private void OnJahrChanged()
    {
        ApplyZeitraum();
        _ = LoadDataAsync();
    }

    private void ApplyZeitraumAndLoad()
    {
        ApplyZeitraum();
        _ = LoadDataAsync();
    }

    private void ApplyZeitraum()
    {
        var jahr = _ausgewaehltesJahr;
        (_von, _bis) = _zeitraum switch
        {
            Zeitraum.Monat => (
                new DateOnly(jahr, _ausgewaehlterMonat, 1),
                new DateOnly(jahr, _ausgewaehlterMonat, DateTime.DaysInMonth(jahr, _ausgewaehlterMonat))
            ),
            Zeitraum.Quartal => (
                new DateOnly(jahr, (_ausgewaehlteQuartal - 1) * 3 + 1, 1),
                new DateOnly(jahr, _ausgewaehlteQuartal * 3, DateTime.DaysInMonth(jahr, _ausgewaehlteQuartal * 3))
            ),
            _ => (new DateOnly(jahr, 1, 1), new DateOnly(jahr, 12, 31))
        };
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var buchungen = await SaldoService.GetAlleBuchungenAsync(_von, _bis);
            _anzahlEinnahmen = buchungen.Count(b => b.Typ == BuchungsTyp.Einnahme);
            _anzahlAusgaben = buchungen.Count(b => b.Typ == BuchungsTyp.Ausgabe);
            _uebersicht = await SaldoService.GetUebersichtAsync(_von, _bis);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Laden: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportDatevAsync()
    {
        _exportingDatev = true;
        try
        {
            var bytes = await ExportService.ExportBuchungsstapelAsync(_von, _bis);
            var quartal = GetQuartal(_von, _bis);
            var fileName = $"EXTF_Buchungsstapel_{_von:yyyy}_{quartal}.csv";
            await DownloadFileAsync(bytes, fileName, "text/csv");
            Snackbar.Add("DATEV-Export erstellt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim DATEV-Export: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exportingDatev = false;
        }
    }

    private async Task ExportBelegeAsync()
    {
        _exportingBelege = true;
        try
        {
            var bytes = await ExportService.ExportBelegeAsync(_von, _bis);
            var quartal = GetQuartal(_von, _bis);
            var fileName = $"Belege_{_von:yyyy}_{quartal}.zip";
            await DownloadFileAsync(bytes, fileName, "application/zip");
            Snackbar.Add("Belege-Export erstellt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Belege-Export: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exportingBelege = false;
        }
    }

    private async Task DownloadFileAsync(byte[] data, string fileName, string contentType)
    {
        var base64 = Convert.ToBase64String(data);
        await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, contentType, base64);
    }

    private static string GetQuartal(DateOnly von, DateOnly bis)
    {
        if (von.Month == 1 && von.Day == 1 && bis.Month == 12 && bis.Day == 31)
            return "FJ";
        return von.Month switch
        {
            1 => "Q1", 4 => "Q2", 7 => "Q3", 10 => "Q4",
            _ => $"{von:MMdd}_{bis:MMdd}"
        };
    }

    private static string GetSaldoBorderStyle(decimal v)
        => "border-left: 4px solid " + (v >= 0 ? "#4caf50" : "#f44336") + ";";
}
