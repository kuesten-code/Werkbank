@page "/projekte/{Id:guid}"
@using Kuestencode.Werkbank.Acta.Domain.Dtos
@using Kuestencode.Werkbank.Acta.Domain.Services
@using Kuestencode.Shared.Contracts.Host
@using Kuestencode.Werkbank.Acta.Shared.Components
@using Kuestencode.Shared.ApiClients
@using Kuestencode.Shared.Contracts.Rapport
@using Kuestencode.Shared.Contracts.Recepta
@using Kuestencode.Shared.Contracts.Faktura
@inject Kuestencode.Werkbank.Acta.Services.IProjectService ProjectService
@inject CoreInterfaces.ICustomerService CustomerService
@inject ProjectStatusService StatusService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IHostApiClient HostApiClient
@inject ModuleAvailabilityService ModuleAvailability
@inject Kuestencode.Werkbank.Acta.Services.IStundensatzService StundensatzService
@inject IFakturaApiClient FakturaClient

<PageTitle>Projekt Details - Küstencode Acta</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_project == null)
    {
        <MudAlert Severity="Severity.Error">Projekt nicht gefunden.</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4">
            <!-- Header -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudStack>
                    <MudText Typo="Typo.h4">@_project.ProjectNumber - @_project.Name</MudText>
                    @if (_customer != null)
                    {
                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@_customer.Name</MudText>
                    }
                </MudStack>
                <ProjectStatusBadge Status="@_project.Status" Size="Size.Large" />
            </MudStack>

            <!-- Tabs -->
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <!-- Tab 1: Stammdaten -->
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudGrid>
                        <!-- Projektdaten -->
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6" GutterBottom="true">Projektdaten</MudText>
                            <MudSimpleTable Dense="true">
                                <tbody>
                                    <tr>
                                        <td><strong>Projektnummer:</strong></td>
                                        <td><strong>@_project.ProjectNumber</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td><ProjectStatusBadge Status="@_project.Status" /></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Erstellt am:</strong></td>
                                        <td>@_project.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    @if (_project.StartDate.HasValue)
                                    {
                                        <tr>
                                            <td><strong>Startdatum:</strong></td>
                                            <td>@_project.StartDate.Value.ToString("dd.MM.yyyy")</td>
                                        </tr>
                                    }
                                    @if (_project.TargetDate.HasValue)
                                    {
                                        <tr>
                                            <td><strong>Zieldatum:</strong></td>
                                            <td>
                                                @{
                                                    var isOverdue = _project.TargetDate.Value < DateOnly.FromDateTime(DateTime.Today)
                                                                    && _project.Status == ProjectStatus.Active;
                                                }
                                                <MudText Color="@(isOverdue ? Color.Error : Color.Default)">
                                                    @_project.TargetDate.Value.ToString("dd.MM.yyyy")
                                                    @if (isOverdue)
                                                    {
                                                        <text> (überfällig)</text>
                                                    }
                                                </MudText>
                                            </td>
                                        </tr>
                                    }
                                    @if (_project.CompletedAt.HasValue)
                                    {
                                        <tr>
                                            <td><strong>Abgeschlossen am:</strong></td>
                                            <td>@_project.CompletedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                        </tr>
                                    }
                                    @if (_project.BudgetNet.HasValue)
                                    {
                                        <tr>
                                            <td><strong>Budget (netto):</strong></td>
                                            <td>@_project.BudgetNet.Value.ToString("C2", _culture)</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudItem>

                        <!-- Kundendaten -->
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6" GutterBottom="true">Kunde</MudText>
                            @if (_customer != null)
                            {
                                <MudText Typo="Typo.body1"><strong>@_customer.Name</strong></MudText>
                                <MudText Typo="Typo.body2">@_customer.CustomerNumber</MudText>
                                <MudText Typo="Typo.body2">@_customer.Address</MudText>
                                <MudText Typo="Typo.body2">@_customer.PostalCode @_customer.City</MudText>
                                @if (!string.IsNullOrEmpty(_customer.Email))
                                {
                                    <MudText Typo="Typo.body2">@_customer.Email</MudText>
                                }
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">Kunde nicht gefunden</MudText>
                            }
                        </MudItem>

                        <!-- Projektadresse -->
                        @if (!string.IsNullOrWhiteSpace(_project.Address) || !string.IsNullOrWhiteSpace(_project.City))
                        {
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.h6" GutterBottom="true">Projektadresse</MudText>
                                @if (!string.IsNullOrWhiteSpace(_project.Address))
                                {
                                    <MudText Typo="Typo.body2">@_project.Address</MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(_project.PostalCode) || !string.IsNullOrWhiteSpace(_project.City))
                                {
                                    <MudText Typo="Typo.body2">@_project.PostalCode @_project.City</MudText>
                                }
                            </MudItem>
                        }

                        <!-- Beschreibung -->
                        @if (!string.IsNullOrWhiteSpace(_project.Description))
                        {
                            <MudItem xs="12" Class="mt-4">
                                <MudText Typo="Typo.h6" GutterBottom="true">Beschreibung</MudText>
                                <MudPaper Class="pa-3" Elevation="0">
                                    <MudText Typo="Typo.body2" Style="white-space: pre-line;">@_project.Description</MudText>
                                </MudPaper>
                            </MudItem>
                        }

                        <!-- Verrechnungssätze -->
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6" GutterBottom="true">Verrechnungssätze</MudText>
                            @if (_verfuegbareRollen.Count == 0)
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.body2">Keine Abrechnungsrollen konfiguriert.</MudText>
                            }
                            else
                            {
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        @foreach (var eingabe in _stundensatzEingaben)
                                        {
                                            <tr @key="@eingabe.RolleId">
                                                <td style="width: 130px;"><strong>@eingabe.RolleName</strong></td>
                                                <td>
                                                    <MudTextField T="string" @bind-Value="eingabe.WertText"
                                                                  Variant="Variant.Text" Adornment="Adornment.End"
                                                                  AdornmentText="€/h" Placeholder="0,00"
                                                                  InputType="InputType.Number" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       Class="mt-2" OnClick="SaveStundensaetzeAsync"
                                       Disabled="@(_isSavingStundensaetze || _stundensatzEingaben.Count == 0)">
                                Speichern
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 2: Aufgaben -->
                <MudTabPanel Text="Aufgaben" Icon="@Icons.Material.Filled.Checklist" BadgeData="@(_project.OpenTasksCount + _project.CompletedTasksCount)" BadgeColor="Color.Primary">
                    <ProjectTaskList ProjectId="@_project.Id"
                                    Disabled="@(!_project.IsEditable)"
                                    OnTasksChanged="RefreshProjectAsync" />
                </MudTabPanel>

                <!-- Tab 3: Übersicht (Placeholder) -->
                <MudTabPanel Text="Übersicht" Icon="@Icons.Material.Filled.Dashboard">
                    @if (_fakturaAvailable || _receptaAvailable || _rapportAvailable)
                    {
                        var einnahmen = _projectInvoices?.TotalNet ?? 0m;
                        var material = _projectExpenses?.TotalNet ?? 0m;
                        var arbeit = _projektAbrechnung?.ArbeitszeitkostenNetto ?? 0m;
                        var ausgaben = material + arbeit;
                        var saldo = einnahmen - ausgaben;
                        <MudPaper Class="pa-3 mb-4" Elevation="1">
                            <MudGrid>
                                <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Einnahmen (netto)</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Success">@einnahmen.ToString("N2", _culture) €</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Ausgaben (netto)</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Error">@ausgaben.ToString("N2", _culture) €</MudText>
                                    @if (arbeit > 0 && material > 0)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Material @material.ToString("N2", _culture) € + Arbeit @arbeit.ToString("N2", _culture) €
                                        </MudText>
                                    }
                                    else if (arbeit > 0)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">davon Arbeit @arbeit.ToString("N2", _culture) €</MudText>
                                    }
                                </MudItem>
                                <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Saldo (netto)</MudText>
                                    <MudText Typo="Typo.h6" Color="@(saldo >= 0 ? Color.Success : Color.Error)">
                                        @(saldo >= 0 ? "+" : "")@saldo.ToString("N2", _culture) €
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                    <MudGrid Style="align-items: stretch;">
                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-4 d-flex flex-column align-center justify-center" Elevation="2" Style="height: 100%;">
                                <MudIcon Icon="@Icons.Material.Filled.TaskAlt" Size="Size.Large" Color="Color.Success" />
                                <MudText Typo="Typo.h4" Class="mt-2">@_project.CompletedTasksCount / @_project.Tasks.Count</MudText>
                                <MudText Typo="Typo.body2">Aufgaben erledigt</MudText>
                                <MudProgressLinear Color="@GetProgressColor(_project.ProgressPercent)"
                                                  Value="@_project.ProgressPercent" Class="mt-2" Style="width: 100%;" />
                                <MudText Typo="Typo.caption">@_project.ProgressPercent% abgeschlossen</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-4 d-flex flex-column align-center justify-center" Elevation="2" Style="height: 100%;">
                                <MudIcon Icon="@Icons.Material.Filled.Euro" Size="Size.Large" Color="Color.Primary" />
                                <MudText Typo="Typo.h4" Class="mt-2">@(_project.BudgetNet?.ToString("N0", _culture) ?? "-") €</MudText>
                                <MudText Typo="Typo.body2">Budget (netto)</MudText>
                            </MudPaper>
                        </MudItem>

                    </MudGrid>

                    @if (_projektAbrechnung != null && (_projektAbrechnung.BerechnetePositionen.Count > 0 || _projektAbrechnung.MaterialBerechnedNetto > 0))
                    {
                        <MudPaper Class="pa-4 mt-4" Elevation="1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                <MudText Typo="Typo.h6">Bereits berechnet</MudText>
                            </MudStack>

                            @if (_projektAbrechnung.BerechnetePositionen.Count > 0)
                            {
                                var berechneteStunden = _projektAbrechnung.BerechnetePositionen.Sum(p => p.Stunden);
                                var berechneteArbeit = _projektAbrechnung.BerechnetePositionen.Sum(p => p.Betrag);
                                <MudText Typo="Typo.subtitle2" Class="mb-1">Arbeitsstunden</MudText>
                                <MudSimpleTable Dense="true" Class="mb-4">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th style="text-align:right">Stunden</th>
                                            <th style="text-align:right">Satz</th>
                                            <th style="text-align:right">Betrag</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pos in _projektAbrechnung.BerechnetePositionen)
                                        {
                                            <tr>
                                                <td>@pos.RolleName</td>
                                                <td style="text-align:right">@pos.Stunden.ToString("N1", _culture) h</td>
                                                <td style="text-align:right">@(pos.Stundensatz > 0 ? pos.Stundensatz.ToString("N2", _culture) + " €" : "–")</td>
                                                <td style="text-align:right">@(pos.Stundensatz > 0 ? pos.Betrag.ToString("N2", _culture) + " €" : "–")</td>
                                            </tr>
                                        }
                                        <tr style="border-top: 1px solid rgba(0,0,0,0.12);">
                                            <td><strong>Gesamt</strong></td>
                                            <td style="text-align:right"><strong>@berechneteStunden.ToString("N1", _culture) h</strong></td>
                                            <td></td>
                                            <td style="text-align:right"><strong>@berechneteArbeit.ToString("N2", _culture) €</strong></td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            }

                            @if (_projektAbrechnung.MaterialBerechnedNetto > 0)
                            {
                                <MudText Typo="Typo.subtitle2" Class="mb-1">Material und externe Aufwände</MudText>
                                <MudSimpleTable Dense="true">
                                    <thead>
                                        <tr>
                                            <th>Belegnr.</th>
                                            <th>Lieferant</th>
                                            <th style="text-align:right">Netto</th>
                                            <th style="text-align:right">Brutto</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (_projektAbrechnung.BerechneteAufwaende.Count > 0)
                                        {
                                            @foreach (var aufwand in _projektAbrechnung.BerechneteAufwaende)
                                            {
                                                <tr>
                                                    <td>@aufwand.Belegnummer</td>
                                                    <td>@aufwand.Lieferant</td>
                                                    <td style="text-align:right">@aufwand.Netto.ToString("N2", _culture) €</td>
                                                    <td style="text-align:right">@aufwand.Brutto.ToString("N2", _culture) €</td>
                                                </tr>
                                            }
                                            <tr style="border-top: 1px solid rgba(0,0,0,0.12);">
                                                <td><strong>Gesamt</strong></td>
                                                <td></td>
                                                <td style="text-align:right"><strong>@_projektAbrechnung.MaterialBerechnedNetto.ToString("N2", _culture) €</strong></td>
                                                <td style="text-align:right"><strong>@_projektAbrechnung.MaterialBerechnedBrutto.ToString("N2", _culture) €</strong></td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="2">Material und ext. Aufwände</td>
                                                <td style="text-align:right">@_projektAbrechnung.MaterialBerechnedNetto.ToString("N2", _culture) €</td>
                                                <td style="text-align:right">@_projektAbrechnung.MaterialBerechnedBrutto.ToString("N2", _culture) €</td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                        </MudPaper>
                    }

                    @if (_rapportAvailable && _projektAbrechnung != null && _projektAbrechnung.Positionen.Count > 0)
                    {
                        var arbeitNetto = _projektAbrechnung.Positionen.Sum(p => p.Betrag);
                        var gesamtStunden = _projektAbrechnung.Positionen.Sum(p => p.Stunden);
                        <MudPaper Class="pa-4 mt-4" Elevation="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Info" />
                                <MudText Typo="Typo.h6">Offene Arbeitsstunden</MudText>
                            </MudStack>
                            <MudSimpleTable Dense="true">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th style="text-align:right">Stunden</th>
                                        <th style="text-align:right">Satz</th>
                                        <th style="text-align:right">Betrag</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pos in _projektAbrechnung.Positionen)
                                    {
                                        <tr>
                                            <td>@pos.RolleName</td>
                                            <td style="text-align:right">@pos.Stunden.ToString("N1", _culture) h</td>
                                            <td style="text-align:right">
                                                @if (pos.Stundensatz > 0)
                                                {
                                                    <text>@pos.Stundensatz.ToString("N2", _culture) €</text>
                                                }
                                                else if (pos.Stunden > 0)
                                                {
                                                    <MudText Color="Color.Warning" Typo="Typo.caption">Kein Satz hinterlegt</MudText>
                                                }
                                                else
                                                {
                                                    <text>–</text>
                                                }
                                            </td>
                                            <td style="text-align:right">
                                                @if (pos.Stundensatz > 0)
                                                {
                                                    <text>@pos.Betrag.ToString("N2", _culture) €</text>
                                                }
                                                else
                                                {
                                                    <text>–</text>
                                                }
                                            </td>
                                        </tr>
                                    }
                                    <tr style="border-top: 1px solid rgba(0,0,0,0.12);">
                                        <td><strong>Gesamt</strong></td>
                                        <td style="text-align:right"><strong>@gesamtStunden.ToString("N1", _culture) h</strong></td>
                                        <td></td>
                                        <td style="text-align:right"><strong>@arbeitNetto.ToString("N2", _culture) €</strong></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }

                    @if (_rapportAvailable && _projektAbrechnung != null && _projektAbrechnung.Arbeitskosten.Count > 0)
                    {
                        <MudPaper Class="pa-4 mt-4" Elevation="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Error" />
                                <MudText Typo="Typo.h6">Arbeitszeitkosten</MudText>
                            </MudStack>
                            <MudSimpleTable Dense="true">
                                <thead>
                                    <tr>
                                        <th>Mitarbeiter</th>
                                        <th style="text-align:right">Stunden</th>
                                        <th style="text-align:right">Kostensatz</th>
                                        <th style="text-align:right">Kosten</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pos in _projektAbrechnung.Arbeitskosten)
                                    {
                                        <tr>
                                            <td>@pos.MitarbeiterName</td>
                                            <td style="text-align:right">@pos.Stunden.ToString("N1", _culture) h</td>
                                            <td style="text-align:right">
                                                @if (pos.Kostensatz > 0)
                                                {
                                                    <text>@pos.Kostensatz.ToString("N2", _culture) €</text>
                                                }
                                                else
                                                {
                                                    <MudText Color="Color.Warning" Typo="Typo.caption">Kein Kostensatz hinterlegt</MudText>
                                                }
                                            </td>
                                            <td style="text-align:right">@pos.Betrag.ToString("N2", _culture) €</td>
                                        </tr>
                                    }
                                    <tr style="border-top: 1px solid rgba(0,0,0,0.12);">
                                        <td><strong>Gesamt</strong></td>
                                        <td style="text-align:right"><strong>@_projektAbrechnung.Arbeitskosten.Sum(p => p.Stunden).ToString("N1", _culture) h</strong></td>
                                        <td></td>
                                        <td style="text-align:right"><strong>@_projektAbrechnung.ArbeitszeitkostenNetto.ToString("N2", _culture) €</strong></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }

                    @if (_receptaAvailable && _projektAbrechnung != null && _projektAbrechnung.MaterialNetto > 0 && _projectExpenses != null)
                    {
                        var billed = _projektAbrechnung.BerechneteAufwaende.Select(a => a.Belegnummer).ToHashSet();
                        var offeneDocs = _projectExpenses.Documents.Where(d => !billed.Contains(d.DocumentNumber)).ToList();
                        <MudPaper Class="pa-4 mt-3" Elevation="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Warning" />
                                <MudText Typo="Typo.h6">Material und externe Aufwände</MudText>
                            </MudStack>
                            <MudSimpleTable Dense="true">
                                <thead>
                                    <tr>
                                        <th>Belegnr.</th>
                                        <th>Lieferant</th>
                                        <th style="text-align:right">Netto</th>
                                        <th style="text-align:right">Brutto</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in offeneDocs)
                                    {
                                        <tr>
                                            <td>@doc.DocumentNumber</td>
                                            <td>@doc.SupplierName</td>
                                            <td style="text-align:right">@((doc.AllocatedNet ?? doc.AmountNet).ToString("N2", _culture)) €</td>
                                            <td style="text-align:right">@((doc.AllocatedGross ?? doc.AmountGross).ToString("N2", _culture)) €</td>
                                        </tr>
                                    }
                                    <tr style="border-top: 1px solid rgba(0,0,0,0.12);">
                                        <td><strong>Gesamt</strong></td>
                                        <td></td>
                                        <td style="text-align:right"><strong>@_projektAbrechnung.MaterialNetto.ToString("N2", _culture) €</strong></td>
                                        <td style="text-align:right"><strong>@_projektAbrechnung.MaterialBrutto.ToString("N2", _culture) €</strong></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }

                    @if ((_rapportAvailable || _receptaAvailable) && _projektAbrechnung != null)
                    {
                        <MudPaper Class="pa-4 mt-3" Elevation="2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6">Abrechnungssumme (netto)</MudText>
                                <MudText Typo="Typo.h5" Color="Color.Primary">
                                    @_projektAbrechnung.GesamtNetto.ToString("N2", _culture) €
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }

                    @if (_fakturaAvailable && _projektAbrechnung != null && _project.Status == ProjectStatus.Active)
                    {
                        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Receipt"
                                       Disabled="@_isCreatingRechnung"
                                       OnClick="CreateRechnungAsync">
                                Rechnung erstellen
                            </MudButton>
                        </MudStack>
                    }
                </MudTabPanel>

                @* Tab 4: Belege (Recepta und/oder Faktura) *@
                @if (_receptaAvailable || _fakturaAvailable)
                {
                    <MudTabPanel Text="Belege" Icon="@Icons.Material.Filled.ReceiptLong"
                                BadgeData="@((_projectExpenses?.DocumentCount ?? 0) + (_projectInvoices?.InvoiceCount ?? 0))" BadgeColor="Color.Warning">
                        <MudExpansionPanels MultiExpansion="true">

                            @* Panel 1: Ausgaben (Recepta) *@
                            @if (_receptaAvailable)
                            {
                                <MudExpansionPanel Text="@($"Belege – Ausgaben ({_projectExpenses?.DocumentCount ?? 0})")" IsInitiallyExpanded="true">
                                    @if (_projectExpenses == null || _projectExpenses.Documents.Count == 0)
                                    {
                                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="pa-4" Align="Align.Center">
                                            Keine Belege diesem Projekt zugeordnet.
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudTable Items="@_projectExpenses.Documents" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                                            <HeaderContent>
                                                <MudTh>Belegnr.</MudTh>
                                                <MudTh>Lieferant</MudTh>
                                                <MudTh>Rechnungsnr.</MudTh>
                                                <MudTh>Datum</MudTh>
                                                <MudTh>Kategorie</MudTh>
                                                <MudTh>Status</MudTh>
                                                <MudTh Style="text-align: right;">Netto</MudTh>
                                                <MudTh Style="text-align: right;">Brutto</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd DataLabel="Belegnr.">
                                                    <MudLink Href="@($"/recepta/belege/{context.Id}")">@context.DocumentNumber</MudLink>
                                                </MudTd>
                                                <MudTd DataLabel="Lieferant">@context.SupplierName</MudTd>
                                                <MudTd DataLabel="Rechnungsnr.">@context.InvoiceNumber</MudTd>
                                                <MudTd DataLabel="Datum">@context.InvoiceDate.ToString("dd.MM.yyyy")</MudTd>
                                                <MudTd DataLabel="Kategorie">
                                                    <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.Category)">
                                                        @GetCategoryText(context.Category)
                                                    </MudChip>
                                                </MudTd>
                                                <MudTd DataLabel="Status">
                                                    <MudChip T="string" Size="Size.Small" Color="@GetDocumentStatusColor(context.Status)">
                                                        @GetDocumentStatusText(context.Status)
                                                    </MudChip>
                                                </MudTd>
                                                <MudTd DataLabel="Netto" Style="text-align: right;">
                                                    @((context.AllocatedNet ?? context.AmountNet).ToString("N2", _culture)) €
                                                    @if (context.AllocatedNet.HasValue && context.AllocatedNet != context.AmountNet)
                                                    {
                                                        <MudTooltip Text="@($"Gesamtbetrag: {context.AmountNet.ToString("N2", _culture)} €")">
                                                            <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                                                        </MudTooltip>
                                                    }
                                                </MudTd>
                                                <MudTd DataLabel="Brutto" Style="text-align: right;">
                                                    @((context.AllocatedGross ?? context.AmountGross).ToString("N2", _culture)) €
                                                    @if (context.AllocatedGross.HasValue && context.AllocatedGross != context.AmountGross)
                                                    {
                                                        <MudTooltip Text="@($"Gesamtbetrag: {context.AmountGross.ToString("N2", _culture)} €")">
                                                            <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                                                        </MudTooltip>
                                                    }
                                                </MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                        <MudPaper Class="pa-3 mt-2" Elevation="0">
                                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="4">
                                                <MudText Typo="Typo.subtitle2">
                                                    Gesamt Netto: <strong>@_projectExpenses.TotalNet.ToString("N2", _culture) €</strong>
                                                </MudText>
                                                <MudText Typo="Typo.subtitle2">
                                                    Gesamt Brutto: <strong>@_projectExpenses.TotalGross.ToString("N2", _culture) €</strong>
                                                </MudText>
                                            </MudStack>
                                        </MudPaper>
                                    }
                                </MudExpansionPanel>
                            }

                            @* Panel 2: Ausgang – Rechnungen (Faktura) *@
                            @if (_fakturaAvailable)
                            {
                                <MudExpansionPanel Text="@($"Ausgang – Rechnungen ({_projectInvoices?.InvoiceCount ?? 0})")" IsInitiallyExpanded="true">
                                    @if (_projectInvoices == null || _projectInvoices.Invoices.Count == 0)
                                    {
                                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="pa-4" Align="Align.Center">
                                            Keine Rechnungen diesem Projekt zugeordnet.
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudTable Items="@_projectInvoices.Invoices" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                                            <HeaderContent>
                                                <MudTh>Rechnungsnr.</MudTh>
                                                <MudTh>Datum</MudTh>
                                                <MudTh>Status</MudTh>
                                                <MudTh Style="text-align: right;">Netto</MudTh>
                                                <MudTh Style="text-align: right;">Brutto</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd DataLabel="Rechnungsnr.">
                                                    <MudLink Href="@($"/faktura/invoices/details/{context.Id}")">@context.InvoiceNumber</MudLink>
                                                </MudTd>
                                                <MudTd DataLabel="Datum">@context.InvoiceDate.ToString("dd.MM.yyyy")</MudTd>
                                                <MudTd DataLabel="Status">
                                                    <MudChip T="string" Size="Size.Small" Color="@GetInvoiceStatusColor(context.Status)">
                                                        @GetInvoiceStatusText(context.Status)
                                                    </MudChip>
                                                </MudTd>
                                                <MudTd DataLabel="Netto" Style="text-align: right;">@context.TotalNetAfterDiscount.ToString("N2", _culture) €</MudTd>
                                                <MudTd DataLabel="Brutto" Style="text-align: right;">@context.TotalGross.ToString("N2", _culture) €</MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                        <MudPaper Class="pa-3 mt-2" Elevation="0">
                                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="4">
                                                <MudText Typo="Typo.subtitle2">
                                                    Gesamt Netto: <strong>@_projectInvoices.TotalNet.ToString("N2", _culture) €</strong>
                                                </MudText>
                                                <MudText Typo="Typo.subtitle2">
                                                    Gesamt Brutto: <strong>@_projectInvoices.TotalGross.ToString("N2", _culture) €</strong>
                                                </MudText>
                                            </MudStack>
                                        </MudPaper>
                                    }
                                </MudExpansionPanel>
                            }

                        </MudExpansionPanels>
                    </MudTabPanel>
                }
            </MudTabs>

            <!-- Actions -->
            <MudDivider Class="my-4" />
            <MudStack Row="true" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled" Color="Color.Default"
                          StartIcon="@Icons.Material.Filled.ArrowBack"
                          OnClick="@(() => NavigationManager.NavigateTo(Kuestencode.Shared.UI.Pages.TabbedListPageBase.BackUrl("/acta/projekte", _fromFilter, _fromSearch)))">
                    Zurück zur Übersicht
                </MudButton>

                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    @* Status-Aktionen basierend auf State Machine *@
                    @foreach (var transition in ProjectStateMachine.GetAvailableTransitions(_project.Status))
                    {
                        <MudButton Variant="Variant.Filled"
                                  Color="@GetTransitionButtonColor(transition.TargetStatus)"
                                  StartIcon="@GetTransitionIcon(transition.TargetStatus)"
                                  OnClick="@(() => ExecuteTransition(transition.TargetStatus, transition.ActionName))">
                            @transition.ActionName
                        </MudButton>
                    }

                    @* Bearbeiten-Button wenn editierbar *@
                    @if (_project.IsEditable)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                  StartIcon="@Icons.Material.Filled.Edit"
                                  OnClick="EditProject">
                            Bearbeiten
                        </MudButton>
                    }

                    @* Löschen nur bei Draft *@
                    @if (_project.Status == ProjectStatus.Draft)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                  StartIcon="@Icons.Material.Filled.Delete"
                                  OnClick="DeleteProject">
                            Löschen
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private readonly System.Globalization.CultureInfo _culture = new("de-DE");
    private bool _loading = true;
    private string? _fromFilter;
    private string? _fromSearch;
    private Project? _project;
    private Customer? _customer;
    private bool _rapportAvailable;
    private ProjectHoursResponseDto? _projectHours;
    private bool _receptaAvailable;
    private ProjectExpensesResponseDto? _projectExpenses;
    private bool _fakturaAvailable;
    private ProjectInvoicesResponseDto? _projectInvoices;
    private List<StundensatzEingabe> _stundensatzEingaben = new();
    private List<MitarbeiterRolleDto> _verfuegbareRollen = new();
    private bool _isSavingStundensaetze;
    private ProjektAbrechnung? _projektAbrechnung;
    private bool _isCreatingRechnung;

    protected override async Task OnInitializedAsync()
    {
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(new Uri(NavigationManager.Uri).Query);
        if (queryParams.TryGetValue("from", out var from)) _fromFilter = from.ToString();
        if (queryParams.TryGetValue("fromsearch", out var fromsearch)) _fromSearch = fromsearch.ToString();

        await LoadDataAsync();
    }

    private async Task LoadDataAsync(bool showLoading = true)
    {
        if (showLoading)
            _loading = true;

        try
        {
            _project = await ProjectService.GetByIdAsync(Id);

            if (_project != null && _customer == null)
            {
                _customer = await CustomerService.GetByIdAsync(_project.CustomerId);
            }

            _verfuegbareRollen = await HostApiClient.GetMitarbeiterRollenAsync();

            if (_project != null)
            {
                var saetze = await StundensatzService.GetStundensaetzeAsync(_project.Id);
                _stundensatzEingaben = _verfuegbareRollen.Select(r => new StundensatzEingabe
                {
                    RolleId = r.Id,
                    RolleName = r.Name,
                    WertText = FormatStundensatz(saetze.FirstOrDefault(s => s.RolleId == r.Id)?.Stundensatz)
                }).ToList();
            }

            await CheckModuleAvailabilityAsync();

            if (_project != null)
            {
                if (!_project.ExternalId.HasValue)
                {
                    await ProjectService.EnsureExternalIdsAsync();
                    _project = await ProjectService.GetByIdAsync(Id);
                }

                if (_rapportAvailable && _project?.ExternalId.HasValue == true)
                {
                    _projectHours = await HostApiClient.GetProjectHoursAsync(_project.ExternalId.Value);
                }

                if (_receptaAvailable && _project?.ExternalId.HasValue == true)
                {
                    _projectExpenses = await HostApiClient.GetProjectExpensesAsync(DeterministicGuid(_project.ExternalId.Value));
                }

                if (_fakturaAvailable && _project?.ExternalId.HasValue == true)
                {
                    _projectInvoices = await HostApiClient.GetProjectInvoicesAsync(_project.ExternalId.Value);
                }

                if (_rapportAvailable || _receptaAvailable)
                {
                    _projektAbrechnung = await StundensatzService.GetProjektAbrechnungAsync(_project.Id);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Laden: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }

        StateHasChanged();
    }

    private async Task CreateRechnungAsync()
    {
        if (_project == null || _projektAbrechnung == null) return;

        if (_customer == null)
        {
            Snackbar.Add("Das Projekt hat keinen Kunden. Bitte zuerst einen Kunden zuweisen.", Severity.Error);
            return;
        }

        var hatMaterial = _projektAbrechnung.MaterialNetto > 0;
        var abrechenbar = _projektAbrechnung.Positionen.Where(p => p.Stunden > 0 && p.Stundensatz > 0).ToList();

        foreach (var pos in _projektAbrechnung.Positionen.Where(p => p.Stunden > 0 && p.Stundensatz == 0))
            Snackbar.Add($"{pos.RolleName}-Stunden werden nicht abgerechnet – kein Stundensatz hinterlegt. Bitte in den Stammdaten ergänzen.", Severity.Warning);

        if (!abrechenbar.Any() && !hatMaterial)
        {
            Snackbar.Add("Keine abrechenbaren Positionen vorhanden.", Severity.Warning);
            return;
        }

        // Bestätigungsdialog
        var parameters = new DialogParameters<Kuestencode.Werkbank.Acta.Shared.Dialogs.RechnungErstellenDialog>
        {
            { x => x.Abrechnung, _projektAbrechnung }
        };
        var dialog = await DialogService.ShowAsync<Kuestencode.Werkbank.Acta.Shared.Dialogs.RechnungErstellenDialog>(
            "Rechnung erstellen", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;

        if (result == null || result.Canceled) return;

        _isCreatingRechnung = true;
        try
        {
            var company = await HostApiClient.GetCompanyAsync();
            var vatRate = company?.IsKleinunternehmer == true ? 0m : 19m;
            var items = new List<CreateInvoiceItemRequest>();

            foreach (var pos in abrechenbar)
                items.Add(new CreateInvoiceItemRequest
                {
                    Description = pos.RolleName,
                    Unit = "Stunden",
                    Quantity = pos.Stunden,
                    UnitPrice = pos.Stundensatz,
                    VatRate = vatRate
                });

            if (hatMaterial)
                items.Add(new CreateInvoiceItemRequest
                {
                    Description = "Material und externe Aufwände",
                    Quantity = 1,
                    UnitPrice = _projektAbrechnung.MaterialNetto,
                    VatRate = vatRate
                });

            var request = new CreateInvoiceRequest
            {
                InvoiceDate = DateTime.SpecifyKind(DateTime.Today, DateTimeKind.Utc),
                CustomerId = _customer.Id,
                ProjectId = _project.ExternalId,
                DiscountType = "None",
                Items = items
            };

            var newInvoice = await FakturaClient.CreateInvoiceAsync(request);

            if (_project.ExternalId.HasValue)
                await StundensatzService.MarkProjectTimeEntriesAsInvoicedAsync(_project.ExternalId.Value);

            if (hatMaterial && _projectExpenses?.Documents != null)
            {
                var aufwaende = _projectExpenses.Documents.Select(doc => new BerechneterAufwandDto
                {
                    Belegnummer = doc.DocumentNumber,
                    Lieferant = doc.SupplierName,
                    Netto = doc.AllocatedNet ?? doc.AmountNet,
                    Brutto = doc.AllocatedGross ?? doc.AmountGross
                });
                await StundensatzService.AddBerechneteAufwaendeAsync(_project.Id, aufwaende);
            }

            NavigationManager.NavigateTo($"/faktura/invoices/details/{newInvoice.Id}", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Erstellen der Rechnung: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCreatingRechnung = false;
        }
    }

    private async Task SaveStundensaetzeAsync()
    {
        if (_project == null) return;

        foreach (var eingabe in _stundensatzEingaben.Where(e => !string.IsNullOrWhiteSpace(e.WertText)))
        {
            var parsed = ParseStundensatz(eingabe.WertText);
            if (parsed is null)
            {
                Snackbar.Add($"'{eingabe.WertText}' ist kein gültiger Stundensatz.", Severity.Warning);
                return;
            }
            if (parsed <= 0)
            {
                Snackbar.Add("Stundensatz muss größer als 0 sein.", Severity.Warning);
                return;
            }
        }

        _isSavingStundensaetze = true;
        try
        {
            foreach (var eingabe in _stundensatzEingaben)
            {
                var wert = ParseStundensatz(eingabe.WertText);
                if (wert is null or <= 0) continue;
                await StundensatzService.UpsertStundensatzAsync(_project.Id, eingabe.RolleId, eingabe.RolleName, wert.Value);
            }

            var saetze = await StundensatzService.GetStundensaetzeAsync(_project.Id);
            foreach (var eingabe in _stundensatzEingaben)
                eingabe.WertText = FormatStundensatz(saetze.FirstOrDefault(s => s.RolleId == eingabe.RolleId)?.Stundensatz);

            if (_rapportAvailable || _receptaAvailable)
                _projektAbrechnung = await StundensatzService.GetProjektAbrechnungAsync(_project.Id);

            Snackbar.Add("Verrechnungssätze gespeichert.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSavingStundensaetze = false;
        }
    }

    private async Task RefreshProjectAsync()
    {
        await LoadDataAsync(showLoading: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (_rapportAvailable && _receptaAvailable && _fakturaAvailable) return;

        await CheckModuleAvailabilityAsync();

        if (_project?.ExternalId.HasValue == true)
        {
            if (_rapportAvailable && _projectHours == null)
                _projectHours = await HostApiClient.GetProjectHoursAsync(_project.ExternalId.Value);
            if (_receptaAvailable && _projectExpenses == null)
                _projectExpenses = await HostApiClient.GetProjectExpensesAsync(DeterministicGuid(_project.ExternalId.Value));
            if (_fakturaAvailable && _projectInvoices == null)
                _projectInvoices = await HostApiClient.GetProjectInvoicesAsync(_project.ExternalId.Value);
            if ((_rapportAvailable || _receptaAvailable) && _projektAbrechnung == null)
                _projektAbrechnung = await StundensatzService.GetProjektAbrechnungAsync(_project.Id);
        }

        StateHasChanged();
    }

    private async Task CheckModuleAvailabilityAsync()
    {
        var availability = await ModuleAvailability.CheckAsync();
        _rapportAvailable  = availability.Rapport;
        _receptaAvailable  = availability.Recepta;
        _fakturaAvailable  = availability.Faktura;
    }

    private Color GetProgressColor(int percent) => percent switch
    {
        100 => Color.Success,
        >= 50 => Color.Info,
        > 0 => Color.Warning,
        _ => Color.Default
    };

    private Color GetTransitionButtonColor(ProjectStatus targetStatus) => targetStatus switch
    {
        ProjectStatus.Active => Color.Success,
        ProjectStatus.Paused => Color.Warning,
        ProjectStatus.Completed => Color.Info,
        ProjectStatus.Archived => Color.Dark,
        _ => Color.Primary
    };

    private static Color GetInvoiceStatusColor(string status) => status switch
    {
        "Paid" => Color.Success,
        "Sent" => Color.Info,
        "Overdue" => Color.Error,
        "Cancelled" => Color.Default,
        _ => Color.Default
    };

    private static string GetInvoiceStatusText(string status) => status switch
    {
        "Draft" => "Entwurf",
        "Sent" => "Versendet",
        "Paid" => "Bezahlt",
        "Overdue" => "Überfällig",
        "Cancelled" => "Storniert",
        _ => status
    };

    private string GetTransitionIcon(ProjectStatus targetStatus) => targetStatus switch
    {
        ProjectStatus.Active => Icons.Material.Filled.PlayArrow,
        ProjectStatus.Paused => Icons.Material.Filled.Pause,
        ProjectStatus.Completed => Icons.Material.Filled.CheckCircle,
        ProjectStatus.Archived => Icons.Material.Filled.Archive,
        _ => Icons.Material.Filled.ArrowForward
    };

    private async Task ExecuteTransition(ProjectStatus targetStatus, string actionName)
    {
        if (_project == null) return;

        var parameters = new DialogParameters<Kuestencode.Werkbank.Acta.Shared.Dialogs.ConfirmDialog>
        {
            { x => x.Title, actionName },
            { x => x.ContentText, $"Möchten Sie das Projekt '{_project.Name}' wirklich {actionName.ToLower()}?" },
            { x => x.ButtonText, actionName },
            { x => x.Color, GetTransitionButtonColor(targetStatus) }
        };

        var dialog = await DialogService.ShowAsync<Kuestencode.Werkbank.Acta.Shared.Dialogs.ConfirmDialog>(actionName, parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            try
            {
                await ProjectService.ChangeStatusAsync(_project.Id, targetStatus);
                Snackbar.Add($"Projekt wurde erfolgreich {GetPastTense(actionName)}.", Severity.Success);
                await LoadDataAsync();
            }
            catch (InvalidOperationException ex)
            {
                Snackbar.Add($"Statusübergang nicht möglich: {ex.Message}", Severity.Warning);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
            }
        }
    }

    private string GetPastTense(string action) => action switch
    {
        "Freigeben" => "freigegeben",
        "Pausieren" => "pausiert",
        "Fortsetzen" => "fortgesetzt",
        "Abschließen" => "abgeschlossen",
        "Reaktivieren" => "reaktiviert",
        "Archivieren" => "archiviert",
        _ => action.ToLower()
    };

    private void EditProject()
    {
        NavigationManager.NavigateTo($"/acta/projekte/{Id}/bearbeiten");
    }

    private async Task DeleteProject()
    {
        if (_project == null) return;

        var parameters = new DialogParameters<Kuestencode.Werkbank.Acta.Shared.Dialogs.ConfirmDialog>
        {
            { x => x.Title, "Projekt löschen" },
            { x => x.ContentText, $"Möchten Sie das Projekt '{_project.Name}' wirklich löschen?" },
            { x => x.ButtonText, "Löschen" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<Kuestencode.Werkbank.Acta.Shared.Dialogs.ConfirmDialog>("Löschen", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            try
            {
                await ProjectService.DeleteAsync(_project.Id);
                Snackbar.Add($"Projekt '{_project.Name}' wurde gelöscht.", Severity.Success);
                NavigationManager.NavigateTo(Kuestencode.Shared.UI.Pages.TabbedListPageBase.BackUrl("/acta/projekte", _fromFilter, _fromSearch));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Fehler beim Löschen: {ex.Message}", Severity.Error);
            }
        }
    }

    // Recepta Hilfsmethoden
    private static Color GetDocumentStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Booked" => Color.Info,
        "Paid" => Color.Success,
        _ => Color.Default
    };

    private static string GetDocumentStatusText(string status) => status switch
    {
        "Draft" => "Entwurf",
        "Booked" => "Verbucht",
        "Paid" => "Bezahlt",
        _ => status
    };

    private static Color GetCategoryColor(string category) => category switch
    {
        "Material" => Color.Primary,
        "Subcontractor" => Color.Secondary,
        "Office" => Color.Info,
        "Travel" => Color.Warning,
        _ => Color.Default
    };

    private static string GetCategoryText(string category) => category switch
    {
        "Material" => "Material",
        "Subcontractor" => "Fremdleistung",
        "Office" => "Büro",
        "Travel" => "Reise",
        "Other" => "Sonstig",
        _ => category
    };

    private static Guid DeterministicGuid(int id)
    {
        var bytes = new byte[16];
        BitConverter.GetBytes(id).CopyTo(bytes, 0);
        bytes[4] = 0xAC;
        bytes[5] = 0x7A;
        return new Guid(bytes);
    }

    private static decimal? ParseStundensatz(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var normalized = input.Trim().Replace(',', '.');
        return decimal.TryParse(normalized, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;
    }

    private static string FormatStundensatz(decimal? value) =>
        value?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";

    private sealed class StundensatzEingabe
    {
        public int RolleId { get; set; }
        public string RolleName { get; set; } = "";
        public string WertText { get; set; } = "";
    }
}
