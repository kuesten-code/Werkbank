<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Als bezahlt markieren</MudText>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="4">
            <MudDatePicker @bind-Date="_paymentDate"
                           Label="Zahlungsdatum"
                           DateFormat="dd.MM.yyyy"
                           Variant="Variant.Outlined"
                           MaxDate="DateTime.Today" />
            @if (HasSkonto)
            {
                <MudSwitch @bind-Value="_skontoApplied" T="bool"
                           Color="Color.Success"
                           Label="@SkontoLabel" />
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Confirm"
                   Disabled="@(!_paymentDate.HasValue)">
            Bezahlt markieren
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter]
    public bool HasSkonto { get; set; }

    [Parameter]
    public bool SkontoWithinDeadline { get; set; }

    [Parameter]
    public decimal? SkontoAmount { get; set; }

    private DateTime? _paymentDate = DateTime.Today;
    private bool _skontoApplied;

    private string SkontoLabel => SkontoAmount.HasValue
        ? $"Skonto abgezogen ({SkontoAmount:N2} €)"
        : "Skonto abgezogen";

    protected override void OnInitialized()
    {
        _skontoApplied = SkontoWithinDeadline;
    }

    void Cancel() => Dialog.Cancel();

    void Confirm() => Dialog.Close(DialogResult.Ok(new MarkAsPaidResult(
        DateOnly.FromDateTime(_paymentDate!.Value),
        _skontoApplied
    )));

    public record MarkAsPaidResult(DateOnly PaymentDate, bool SkontoApplied);
}
