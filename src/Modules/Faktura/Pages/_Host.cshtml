@page "/"
@using Microsoft.AspNetCore.Components.Web
@using Kuestencode.Faktura
@namespace Kuestencode.Faktura.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/faktura/" />
    <title>Küstencode Faktura</title>
    <link rel="icon" type="image/png" href="company/logos/Faktura_Logo.png" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="_content/Kuestencode.Shared.UI/css/shared.css?v=@Kuestencode.Shared.UI.AppVersion.Token" rel="stylesheet" />
    <link href="css/site.css?v=@Kuestencode.Shared.UI.AppVersion.Token" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            Ein Fehler ist aufgetreten. Diese Anwendung reagiert möglicherweise nicht mehr, bis sie neu geladen wird.
        </environment>
        <environment include="Development">
            Ein unbehandelter Fehler ist aufgetreten. Details finden Sie in der Browser-Konsole.
        </environment>
        <a href="" class="reload">Neu laden</a>
        <a class="dismiss">🗙</a>
    </div>

    <script>
        window.__werkbank_jwt = '@(HttpContext.Request.Cookies["werkbank_auth_cookie"] ?? (HttpContext.Request.Headers["Authorization"].FirstOrDefault() ?? "").Replace("Bearer ", ""))';
    </script>
    <script src="_framework/blazor.server.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        function openInNewTab(url) {
            var a = document.createElement('a');
            a.href = url;
            a.target = '_blank';
            a.rel = 'noopener noreferrer';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        function downloadFile(filename, base64Data) {
            const linkSource = `data:application/pdf;base64,${base64Data}`;
            const downloadLink = document.createElement("a");
            downloadLink.href = linkSource;
            downloadLink.download = filename;
            downloadLink.click();
        }

        function printPdfFromBase64(base64Data) {
            const pdfData = atob(base64Data);
            const bytes = new Uint8Array(pdfData.length);
            for (let i = 0; i < pdfData.length; i++) {
                bytes[i] = pdfData.charCodeAt(i);
            }
            const blob = new Blob([bytes], { type: 'application/pdf' });
            const url = URL.createObjectURL(blob);

            const iframe = document.createElement('iframe');
            iframe.style.cssText = 'position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;border:none;';
            iframe.src = url;
            document.body.appendChild(iframe);
            iframe.onload = function () {
                try {
                    iframe.contentWindow.focus();
                    iframe.contentWindow.print();
                } catch (e) {
                    window.open(url, '_blank');
                }
                setTimeout(function () {
                    document.body.removeChild(iframe);
                    URL.revokeObjectURL(url);
                }, 60000);
            };
        }

        async function printPdfSequence(base64List) {
            if (!Array.isArray(base64List) || base64List.length === 0) {
                return;
            }

            for (const base64Data of base64List) {
                await new Promise((resolve) => {
                    const pdfData = atob(base64Data);
                    const bytes = new Uint8Array(pdfData.length);
                    for (let i = 0; i < pdfData.length; i++) {
                        bytes[i] = pdfData.charCodeAt(i);
                    }
                    const blob = new Blob([bytes], { type: 'application/pdf' });
                    const url = URL.createObjectURL(blob);

                    const printWindow = window.open(url, '_blank');
                    if (!printWindow) {
                        resolve();
                        return;
                    }

                    const cleanup = () => {
                        try {
                            printWindow.close();
                        } catch { }
                        resolve();
                    };

                    printWindow.onload = function () {
                        try {
                            printWindow.focus();
                            printWindow.print();
                        } catch { }
                    };

                    printWindow.onafterprint = cleanup;
                    setTimeout(cleanup, 10000);
                });
            }
        }
    </script>
</body>
</html>
