# Küstencode Werkbank - Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.

# ============================================================
# Datenbank
# ============================================================
POSTGRES_DB=kuestencode_werkbank
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# ============================================================
# JWT-Authentifizierung
# ============================================================
# Mindestens 32 Zeichen, zufällig generieren:
# openssl rand -base64 32
JWT_SECRET=change_me_use_a_long_random_string_here

# ============================================================
# Module aktivieren (true/false)
# ============================================================
MODULE_FAKTURA=true
MODULE_OFFERTE=true
MODULE_RAPPORT=true
MODULE_ACTA=true
MODULE_RECEPTA=true
MODULE_SALDO=true

# ============================================================
# Versions-Tags (für docker pull / CI-CD)
# ============================================================
MODULE_VERSION_FAKTURA=latest
MODULE_VERSION_OFFERTE=latest
MODULE_VERSION_RAPPORT=latest
MODULE_VERSION_ACTA=latest
MODULE_VERSION_RECEPTA=latest
MODULE_VERSION_SALDO=latest
